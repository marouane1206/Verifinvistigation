# Supabase Configuration
# Replace these values with your actual Supabase credentials

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin Configuration
# These credentials are used for admin authentication
VITE_ADMIN_EMAIL=admin@verifinvestigation.org
VITE_ADMIN_PASSWORD=Admin@2024!Secure

# Service Role Key (for admin setup script only)
# Get this from Supabase Dashboard > Settings > API > Service Role Key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==============================================================================
# SMTP Configuration for Email Delivery
# ==============================================================================
# IMPORTANT: Configure these in your Supabase Dashboard, not in .env
# Go to: Authentication > Providers > Email > SMTP
#
# For local development, Supabase uses Inbucket (configured in supabase/config.toml)
# For production, you need to configure a custom SMTP server
#
# Example SMTP providers:
# - SendGrid: smtp.sendgrid.net (port 587)
# - Mailgun: smtp.mailgun.org (port 587)
# - AWS SES: email-smtp.us-east-1.amazonaws.com (port 587)
# - Gmail: smtp.gmail.com (port 587) - requires app password
#
# Required Supabase Dashboard Settings:
# 1. Go to Authentication > Providers > Email
# 2. Enable "Confirm email" 
# 3. Scroll to "SMTP" section and enable it
# 4. Enter your SMTP server details:
#    - Host: your-smtp-server.com
#    - Port: 587 (or 465 for SSL)
#    - Username: your-smtp-username
#    - Password: your-smtp-password
#    - Sender email: noreply@yourdomain.com
#    - Sender name: Verifinvestigation

# Site URL (used for email confirmation links)
# This should match your production domain
SITE_URL=https://marouane1206.github.io/Verifinvistigation
